; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

_global_script_classes=[ {
"base": "Node2D",
"class": "Head_Object",
"language": "GDScript",
"path": "res://TscnAndGd/Objects/Head_Object_Script.gd"
}, {
"base": "Node",
"class": "Statistics",
"language": "GDScript",
"path": "res://TscnAndGd/Main/Player/Stat.gd"
} ]
_global_script_class_icons={
"Head_Object": "",
"Statistics": ""
}

[application]

config/name="Feed The Cups"
run/main_scene="res://TscnAndGd/UI/Main/Start.tscn"
config/use_custom_user_dir=true
run/low_processor_mode_sleep_usec=30000
config/icon="res://Icon_256_png.png"

[autoload]

SteamLogic="*res://TscnAndGd/Logics/SystemLogic/SteamLogic.tscn"
GameLogic="*res://TscnAndGd/Logics/GameLogic/GameLogic.tscn"

[display]

window/size/width=1920
window/size/height=1080
window/size/borderless=0
window/size/fullscreen=1
window/size/test_width=1280.0
window/size/test_height=720.0
window/dpi/allow_hidpi=true
window/vsync/vsync_via_compositor=true
window/stretch/mode="2d"
window/stretch/aspect="keep"

[editor_plugins]

enabled=PoolStringArray(  )

[global]

"show mini"=false
phys=false
mono=true
render=false
RESET=false
re=false
"调试"=true
rced=false
theme=false

[gui]

theme/use_hidpi=true
theme/custom_font="res://Language/Fonts/Base.tres"

