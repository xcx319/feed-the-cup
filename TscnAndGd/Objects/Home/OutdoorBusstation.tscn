[sub_resource type="GDScript" id=10]
script/source = "extends Head_Object

var cur_Uesd : bool = false # 当前是否被使用。
var _playerNode
var cur_ID : int = 0
var bodyCount : int = 0
var _player1_stat : int = -1
var _player2_stat : int = -1
onready var WaitAni = get_node(\"AniNode/WaitingAni\")
func _ready() -> void:
	set_process_input(false)

func _on_Area2D_body_entered(body: Node) -> void:
	if body.has_method(\"call_change_avatar\"):
		if body.cur_Player == 1:
			_player1_stat = 0
		if body.cur_Player == 2:
			_player2_stat = 0
		if _player1_stat > -1 or _player2_stat > -1:
			_level_ready()
#		print(\"_player1:\",_player1_stat,\"_player2:\",_player1_stat)
func _on_Area2D_body_exited(body: Node) -> void:
	if body.has_method(\"call_change_avatar\"):
		if body.cur_Player == 1:
			_player1_stat = -1
		if body.cur_Player == 2:
			_player2_stat = -1
		if _player1_stat == -1 and _player2_stat == -1:
			_level_ready()
func _level_ready(): # 加载Level倒计时
	if !GameLogic.Player2_bool: # 单人玩家情况
		if _player1_stat == 0:
			### 加载关卡 ####
			# 倒计时效果
			WaitAni.play(\"321\")

	else: # 双人情况
		if _player1_stat == 0 and _player2_stat == 0:
			### 加载关卡 ####
			WaitAni.play(\"321\")
			pass
		elif _player1_stat == 0 and _player2_stat != 0:
			### 显示等待2P
			WaitAni.play(\"waiting\")
			pass
		elif _player1_stat != 0 and _player2_stat == 0:
			### 显示等待1P
			WaitAni.play(\"waiting\")
		else:
			WaitAni.play(\"init\")
	pass


func _on_Timer_timeout() -> void:
	GameLogic.LoadingUI.call_LevelLoad(\"1_2\")
"

