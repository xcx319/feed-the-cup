func DataSave():


	var save_path = SAVE_DIR + dataSavedName + save_suffix

	var file = File.new()
	var dir = Directory.new()

	if dir.open(SAVE_DIR) != OK:
		print(SAVE_DIR, " 文件夹不存在,执行创建新文件夹。")
		dir.make_dir(SAVE_DIR)


	var error = file.open(save_path, File.WRITE)
	if error == OK:

		DataInfo()
		file.store_var(allData)

	else:
		print("saveerror:", error)
	file.close()
	pass

func DataInfo():

	var savetime = OS.get_datetime()
	saveDataInfo[dataSavedName] = {"savetime": savetime}
	DataInfo_Save()
func DataInfo_Save():
	var save_path = SAVE_DIR + saveDataInfo_suffix
	var file = File.new()
	var error = file.open(save_path, File.READ_WRITE)

	if error == OK:
		file.store_var(saveDataInfo)
	else:
		error = file.open(save_path, File.WRITE)
		if error == OK:
			file.store_var(saveDataInfo)
		else:
			print("生成存档配置文件失败。error:", error)
	file.close()

func Del_DataInfo(_curDataName):
	saveDataInfo.erase(_curDataName)
	DataInfo_Save()

func Del_GameData(_curDataName):
	var _path = SAVE_DIR + _curDataName + save_suffix
	var dir = Directory.new()
	var error = dir.file_exists(_path)
	if error == true:
		dir.remove(_path)
		pass

func DataLoad():
	var save_path = SAVE_DIR + dataSavedName + save_suffix

	var file = File.new()
	if file.file_exists(save_path):
		var error = file.open(save_path, File.READ)
		if error == OK:
			allData = file.get_var()

		else:
			print("SavesFileError:" + error)
	else:
		print("SaveData Loaderror：file_exists = false")
	file.close()
	dataSYNC()
	pass

