custom_fonts/font = SubResource( 2 )
text = "天天996辛苦上班的熊熊，领着较低的工资，住在廉价的房子里。

身心疲惫的它，早已被黑暗中的恶魔注意已久...

恶魔在它身边低声：想要赚更多的钱吗？想要住更宽阔的家吗？与我们缔结契约，实现你的梦想！

虽然我很想走上人生巅峰，可我并不愿意做杀人放火的勾当。

恶魔继续说道：时代变了，饮品行业将是我们改变你人生的选择。"
align = 1
valign = 1
autowrap = true
percent_visible = 0.55
