bbcode_enabled = true
bbcode_text = "从冰淇淋机里取下原料罐，加入三种原料，其中牛奶和鲜奶油是必须原料，而第三种原料将决定冰淇淋的口味。
将原料罐放回冰淇淋机后，机器会开始运行。"
text = "从冰淇淋机里取下原料罐，加入三种原料，其中牛奶和鲜奶油是必须原料，而第三种原料将决定冰淇淋的口味。
将原料罐放回冰淇淋机后，机器会开始运行。"
script = ExtResource( 13 )
LabelTEXT = "信息-文字说明-207"
Center_Bool = true

