bbcode_enabled = true
bbcode_text = "预制好的罐头可以放在货架或冰柜里储存。
由于不能在易拉罐里加入冰块，如果客人需要冰冷的易拉罐，需要提前将汽水罐放入冷藏柜，一段时间后取出就是冰冷的啦。"
text = "预制好的罐头可以放在货架或冰柜里储存。
由于不能在易拉罐里加入冰块，如果客人需要冰冷的易拉罐，需要提前将汽水罐放入冷藏柜，一段时间后取出就是冰冷的啦。"
script = ExtResource( 23 )
