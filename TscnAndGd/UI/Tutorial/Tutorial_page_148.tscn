custom_colors/default_color = Color( 0, 0, 0, 1 )
bbcode_enabled = true
bbcode_text = "啤酒桶可以收纳在酒桶架上，空酒桶不可以扔进垃圾桶。
每次订新的酒桶时，送货小哥会顺手带走一个空酒桶，并且返还酒桶的押金。
如果空桶太多，你也可以支付上门费用，直接呼叫回收服务。"
text = "啤酒桶可以收纳在酒桶架上，空酒桶不可以扔进垃圾桶。
每次订新的酒桶时，送货小哥会顺手带走一个空酒桶，并且返还酒桶的押金。
如果空桶太多，你也可以支付上门费用，直接呼叫回收服务。"
