custom_colors/default_color = Color( 0, 0, 0, 1 )
bbcode_enabled = true
bbcode_text = "下大雪了！积雪会使路面湿滑行动困难，持续下雪会形成大块的雪堆。
为了保证主路通畅，你可以使用推雪铲把积雪推到路边绿化带上，那里不会有顾客行走。
不要把大块的雪堆推到顾客身上，他们会生气的。"
text = "下大雪了！积雪会使路面湿滑行动困难，持续下雪会形成大块的雪堆。
为了保证主路通畅，你可以使用推雪铲把积雪推到路边绿化带上，那里不会有顾客行走。
不要把大块的雪堆推到顾客身上，他们会生气的。"
