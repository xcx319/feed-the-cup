custom_colors/default_color = Color( 0, 0, 0, 1 )
bbcode_enabled = true
bbcode_text = "不管杯子里是啤酒还是啤酒泡，都被视作啤酒，因此啤酒x6并不代表一定要接6份啤酒，你需要根据杯子大小和客人的要求自行判断。
中大杯的容量更多，能溢出更多啤酒泡，泡泡溢出后你也可以出杯，但是可能不会获得好评。"
text = "不管杯子里是啤酒还是啤酒泡，都被视作啤酒，因此啤酒x6并不代表一定要接6份啤酒，你需要根据杯子大小和客人的要求自行判断。
中大杯的容量更多，能溢出更多啤酒泡，泡泡溢出后你也可以出杯，但是可能不会获得好评。"
script = ExtResource( 17 )
LabelTEXT = "信息-文字说明-230"
Center_Bool = true

