bbcode_text = "蒸汽机需要先开机预热，等温度超过100度后才会产生蒸汽，气压指针指向绿色区域时，可使用蒸汽加热杯子里的饮料。
下班时如果不关机，会消耗较多的电，但是第二天可以立刻使用蒸汽。"
text = "蒸汽机需要先开机预热，等温度超过100度后才会产生蒸汽，气压指针指向绿色区域时，可使用蒸汽加热杯子里的饮料。
下班时如果不关机，会消耗较多的电，但是第二天可以立刻使用蒸汽。"
script = ExtResource( 4 )
LabelTEXT = "信息-文字说明-49"
Center_Bool = true
