bbcode_enabled = true
bbcode_text = "当听到准备跑步的哨声，你会自动换上运动衫。请暂时放下手上的工作，到起跑线做好准备！

听到枪声后比赛开始，你必须依次踩中跑道上的计分点，不可以作弊或者抢跑哦。

只要你能完成比赛，观看的顾客就会非常开心，提升你可以获得的小费。但是如果你消极比赛，超过了10秒还没有完成，则会开始加压。"
text = "当听到准备跑步的哨声，你会自动换上运动衫。请暂时放下手上的工作，到起跑线做好准备！

听到枪声后比赛开始，你必须依次踩中跑道上的计分点，不可以作弊或者抢跑哦。

只要你能完成比赛，观看的顾客就会非常开心，提升你可以获得的小费。但是如果你消极比赛，超过了10秒还没有完成，则会开始加压。"
script = ExtResource( 28 )
