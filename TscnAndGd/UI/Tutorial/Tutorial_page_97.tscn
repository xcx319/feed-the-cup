custom_colors/default_color = Color( 0, 0, 0, 1 )
bbcode_enabled = true
bbcode_text = "暂时不使用的原料必须保存在冷冻柜里。
冷藏可以略微保鲜，但隔夜仍然会变{Stale}。在常温环境下隔夜，不管是否开盖都会直接变{Spoiled}。"
text = "暂时不使用的原料必须保存在冷冻柜里。
冷藏可以略微保鲜，但隔夜仍然会变{Stale}。在常温环境下隔夜，不管是否开盖都会直接变{Spoiled}。"
script = ExtResource( 22 )
LabelTEXT = "信息-文字说明-152"
Center_Bool = true

[node name="153" type="RichTextLabel" parent="."]
margin_left = -396.0
margin_top = -222.0
margin_right = 393.0
margin_bottom = -17.0
custom_colors/default_color = Color( 0, 0, 0, 1 )
bbcode_enabled = true
bbcode_text = "冷冻原料需要解冻后才可以开盖使用，放在常温或冷藏环境里会缓慢解冻。
如果想要快速解冻，可将原料放入接满冷水的大锅中，加速解冻。
解冻时不可使用热水，解冻后的原料不可以放回冷冻柜复冻。"
text = "冷冻原料需要解冻后才可以开盖使用，放在常温或冷藏环境里会缓慢解冻。
如果想要快速解冻，可将原料放入接满冷水的大锅中，加速解冻。
解冻时不可使用热水，解冻后的原料不可以放回冷冻柜复冻。"
script = ExtResource( 22 )
LabelTEXT = "信息-文字说明-153"
Center_Bool = true

