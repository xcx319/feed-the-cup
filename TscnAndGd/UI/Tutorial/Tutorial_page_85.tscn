[node name="汽水" type="Node2D"]

[node name="142" type="RichTextLabel" parent="."]
margin_left = -351.0
margin_top = -100.0
margin_right = 470.0
margin_bottom = 81.0
custom_colors/default_color = Color( 0, 0, 0, 1 )
bbcode_enabled = true
bbcode_text = "在{Soft Drink Blender}里可以大量调配不同口味的汽水。
取下一个{Water Tank}，先加入5份青柠原浆，此时通过配方预览可以看到，再加5份水可以配成青柠汽水。
批量制作时，液体总量不可超出水缸容量（40份），否则配比不正确就只能作废了。"
text = "在{Soft Drink Blender}里可以大量调配不同口味的汽水。
取下一个{Water Tank}，先加入5份青柠原浆，此时通过配方预览可以看到，再加5份水可以配成青柠汽水。
批量制作时，液体总量不可超出水缸容量（40份），否则配比不正确就只能作废了。"
script = ExtResource( 33 )
LabelTEXT = "信息-文字说明-142"
Center_Bool = true

[node name="143" type="RichTextLabel" parent="."]
margin_left = -62.0
margin_top = 105.0
margin_right = 485.0
margin_bottom = 352.0
custom_colors/default_color = Color( 0, 0, 0, 1 )
bbcode_enabled = true
bbcode_text = "将调好配比的{Water Tank}放回{Soft Drink Blender}，拿一个{Gas Bottle}对着机器长按进行加气，直到气泡状态达到配方的要求。
{Water Tank}内的气量会缓慢下降，注意机器界面的颜色，气量下降到一定程度就会改变气泡状态。"
text = "将调好配比的{Water Tank}放回{Soft Drink Blender}，拿一个{Gas Bottle}对着机器长按进行加气，直到气泡状态达到配方的要求。
{Water Tank}内的气量会缓慢下降，注意机器界面的颜色，气量下降到一定程度就会改变气泡状态。"
script = ExtResource( 33 )
LabelTEXT = "信息-文字说明-143"
Center_Bool = true

