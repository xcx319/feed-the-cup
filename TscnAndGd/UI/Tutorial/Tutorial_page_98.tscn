bbcode_enabled = true
bbcode_text = "在易拉罐中加入汽水，再封上盖子，就可以出杯啦。
在没有订单的情况下，你也可以提前预制易拉罐，但是要注意没有密封的易拉罐隔夜后，气泡会完全损失，封上盖子的易拉罐则可以维持气量。"
text = "在易拉罐中加入汽水，再封上盖子，就可以出杯啦。
在没有订单的情况下，你也可以提前预制易拉罐，但是要注意没有密封的易拉罐隔夜后，气泡会完全损失，封上盖子的易拉罐则可以维持气量。"
script = ExtResource( 22 )
LabelTEXT = "信息-文字说明-155"
Center_Bool = true

