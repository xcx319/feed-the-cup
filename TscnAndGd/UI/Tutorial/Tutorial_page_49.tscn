bbcode_enabled = true
bbcode_text = "在水槽处过滤后，煮好的西米就可以装入小料盒。
小料盒可以放在料盒专用冰柜里保存。
如果糊掉了，记住要先过滤才能倒进垃圾桶。"
text = "在水槽处过滤后，煮好的西米就可以装入小料盒。
小料盒可以放在料盒专用冰柜里保存。
如果糊掉了，记住要先过滤才能倒进垃圾桶。"
script = ExtResource( 6 )
LabelTEXT = "信息-文字说明-86"
Center_Bool = true
