[node name="煮茶" type="Node2D"]

[node name="115" type="RichTextLabel" parent="."]
margin_left = 50.0
margin_top = 268.0
margin_right = 875.0
margin_bottom = 410.0
custom_colors/default_color = Color( 0, 0, 0, 1 )
bbcode_enabled = true
bbcode_text = "想要泡茶先要学会使用厨房称。
抖动红茶包装袋倒出茶叶，当茶叶超过50g，用滤网打包出一个红茶包。
茶包不能低于50g，而超出的部分不会影响泡茶。"
text = "想要泡茶先要学会使用厨房称。
抖动红茶包装袋倒出茶叶，当茶叶超过50g，用滤网打包出一个红茶包。
茶包不能低于50g，而超出的部分不会影响泡茶。"
script = ExtResource( 14 )
LabelTEXT = "信息-文字说明-115"
Center_Bool = true

