[node name="气体消耗" type="Node2D"]
position = Vector2( 949, 709 )

[node name="144" type="RichTextLabel" parent="."]
margin_left = -397.0
margin_top = -31.0
margin_right = 455.0
margin_bottom = 213.0
custom_colors/default_color = Color( 0, 0, 0, 1 )
bbcode_enabled = true
bbcode_text = "高难度的复合配方需要两种原浆，配比正确后，再加入水混合而成。
液体越多充气时消耗的二氧化碳也越多，每日尽量估算当天需要的汽水量，可以节省不少成本。

一个{Water Tank}最多可以装40份液体，当原浆量过多导致总量超出容量时，无法配比成功。"
text = "高难度的复合配方需要两种原浆，配比正确后，再加入水混合而成。
液体越多充气时消耗的二氧化碳也越多，每日尽量估算当天需要的汽水量，可以节省不少成本。

一个{Water Tank}最多可以装40份液体，当原浆量过多导致总量超出容量时，无法配比成功。"
script = ExtResource( 23 )
LabelTEXT = "信息-文字说明-144"
Center_Bool = true

