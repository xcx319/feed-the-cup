custom_colors/default_color = Color( 0, 0, 0, 1 )
bbcode_enabled = true
bbcode_text = "每一款汽水的气泡量都有一定要求。
出品的汽水气量达到要求或超出要求，客人都会给予{Good Review}。
气泡量不足会给予{Neutral Review}。
如果完全没有气，就不能称为汽水了，客人会给{Bad Review}。"
text = "每一款汽水的气泡量都有一定要求。
出品的汽水气量达到要求或超出要求，客人都会给予{Good Review}。
气泡量不足会给予{Neutral Review}。
如果完全没有气，就不能称为汽水了，客人会给{Bad Review}。"
script = ExtResource( 17 )
LabelTEXT = "信息-文字说明-147"
Center_Bool = true

