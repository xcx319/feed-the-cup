[node name="226" type="RichTextLabel" parent="."]
margin_left = -381.0
margin_top = 154.0
margin_right = 457.0
margin_bottom = 390.0
custom_colors/default_color = Color( 0, 0, 0, 1 )
bbcode_enabled = true
bbcode_text = "将装满啤酒的木桶放在桌子上，安装上酒嘴。
使用扎啤杯接取啤酒，啤酒会额外形成啤酒泡，仅消耗一份啤酒就可以接满一个容量两份的小酒杯。
拧开酒嘴后啤酒不会停下，你需要在合适的时机关闭酒嘴，否则啤酒泡会溢出杯子。
"
text = "将装满啤酒的木桶放在桌子上，安装上酒嘴。
使用扎啤杯接取啤酒，啤酒会额外形成啤酒泡，仅消耗一份啤酒就可以接满一个容量两份的小酒杯。
拧开酒嘴后啤酒不会停下，你需要在合适的时机关闭酒嘴，否则啤酒泡会溢出杯子。
"
script = ExtResource( 14 )
LabelTEXT = "信息-文字说明-226"
Center_Bool = true

