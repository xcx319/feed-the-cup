[node name="煮珍珠" type="Node2D"]

[node name="127" type="RichTextLabel" parent="."]
margin_left = 97.0
margin_top = 272.0
margin_right = 853.0
margin_bottom = 414.0
custom_colors/default_color = Color( 0, 0, 0, 1 )
bbcode_enabled = true
bbcode_text = "煮珍珠需要用到珍珠锅，它有定时和自动开盖功能，不用担心煮糊。
装满水后它会开始加热，水热后会打开盖子，这时需要加入粉圆等待它继续加热。
"
text = "煮珍珠需要用到珍珠锅，它有定时和自动开盖功能，不用担心煮糊。
装满水后它会开始加热，水热后会打开盖子，这时需要加入粉圆等待它继续加热。
"
script = ExtResource( 18 )
LabelTEXT = "信息-文字说明-127"
Center_Bool = true

[node name="128" type="RichTextLabel" parent="."]
margin_left = 111.0
margin_top = 627.0
margin_right = 818.0
margin_bottom = 829.0
custom_colors/default_color = Color( 0, 0, 0, 1 )
bbcode_enabled = true
bbcode_text = "粉圆煮软后锅会自动开盖，你需要将水过滤出。
在锅中继续加入黑糖，它会自动完成焖糖的工作。
盖子弹开后，黑糖珍珠就做好了！"
text = "粉圆煮软后锅会自动开盖，你需要将水过滤出。
在锅中继续加入黑糖，它会自动完成焖糖的工作。
盖子弹开后，黑糖珍珠就做好了！"
script = ExtResource( 18 )
LabelTEXT = "信息-文字说明-128"
Center_Bool = true

